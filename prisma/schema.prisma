// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   BigInt         @id @default(autoincrement())
  username             String
  email                String         @unique
  password             String
  refresh              Refresh_token?
  participant_one_chat Chat[]         @relation("participant one")
  participant_two_chat Chat[]         @relation("participant two")
  sent_messages        Message[]
}

model Refresh_token {
  id      BigInt @id @default(autoincrement())
  token   String @unique
  user    User   @relation(fields: [user_id], references: [id])
  user_id BigInt @unique
}

model Chat {
  id                 BigInt    @id @default(autoincrement())
  messages           Message[]
  participant_one    User      @relation("participant one", fields: [participant_one_id], references: [id])
  participant_two    User      @relation("participant two", fields: [participant_two_id], references: [id])
  participant_one_id BigInt
  participant_two_id BigInt

  @@unique([participant_one_id, participant_two_id])
}

model Message {
  id        BigInt      @id @default(autoincrement())
  type      MessageType
  content   String      @default("")
  chat      Chat        @relation(fields: [chat_id], references: [id])
  chat_id   BigInt
  sender    User        @relation(fields: [sender_id], references: [id])
  sender_id BigInt
}

enum MessageType {
  text
  audio
  video
}
